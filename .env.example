# Banco de dados local (SQLite). Path relativo ao prisma/schema.prisma → prisma/dev.db
DATABASE_URL="file:./dev.db"

# Segredo usado para assinar o cookie de sessao (POC).
# Em Netlify: defina SESSION_SECRET no painel (nao commitar valor real).
SESSION_SECRET="bibi-poc-dev-secret-change-me"

# Detectado automaticamente na Netlify (netlify.toml). Nao precisa no .env local.
# NETLIFY="true"

# Gateway de pagamento: mock (POC) | asaas | efi | inter
PAYMENT_GATEWAY=mock

# Comunicacao: console (POC) | sendgrid | twilio | meta
COMMUNICATION_PROVIDER=console

# Job agendado (lembretes + webhook retry): header x-cron-secret
# CRON_SECRET=change-me-in-production

# URL base das salas de telemedicina (POC mock)
# TELEMEDICINE_BASE_URL=https://meet.bibi.health

# URL publica do site (SEO: metadata, sitemap, Open Graph). Na Netlify use URL ou defina manualmente.
# NEXT_PUBLIC_SITE_URL=https://sistema-bibi.netlify.app

# Volume da massa de dados do seed: small | medium (padrao) | large
# SEED_SCALE=medium

# Restaurar modo demo via UI (/interno/seguranca). Padrao: habilitado fora de producao
# ALLOW_DEMO_RESET=true
