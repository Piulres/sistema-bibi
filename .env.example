# =============================================================================
# Sistema Bibi — variáveis de ambiente (copie para .env)
# Documentação completa: docs/VARIAVEIS_AMBIENTE.md
# =============================================================================

# --- Banco de dados (obrigatório) ---
# Path relativo ao prisma/schema.prisma → prisma/dev.db
DATABASE_URL="file:./dev.db"

# --- Sessão e segurança (obrigatório em produção) ---
# Assina cookie bibi_session e tokens MFA. Troque em produção (≥ 32 chars).
SESSION_SECRET="bibi-poc-dev-secret-change-me"

# --- Segmento / white-label em dev (opcional) ---
# Mapeia host local → slug do tenant. Ex.: {"petcare.localhost":"petcare"}
# DEV_TENANT_HOST_MAP='{"petcare.localhost":"petcare","lex.localhost":"lex"}'

# --- Pagamentos (POC: mock) ---
# Valores: mock | asaas | efi | inter
PAYMENT_GATEWAY=mock
# Credenciais futuras (não usadas pelo código hoje):
# ASAAS_API_KEY=
# EFI_CLIENT_ID=
# EFI_CLIENT_SECRET=
# INTER_CLIENT_ID=
# INTER_CLIENT_CERT=

# --- Comunicação (POC: console) ---
# Valores: console | sendgrid | twilio | meta
COMMUNICATION_PROVIDER=console
# Credenciais futuras (não usadas pelo código hoje):
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# META_WHATSAPP_TOKEN=

# --- Jobs agendados (cron) ---
# Header x-cron-secret em POST /api/cron/reminders e /api/cron/webhooks
# CRON_SECRET=change-me-in-production

# --- Telemedicina ---
# Base das salas virtuais mock (agenda modality=TELE)
# TELEMEDICINE_BASE_URL=https://meet.bibi.health

# --- SEO (opcional) ---
# URL pública para sitemap, Open Graph. Na Netlify use URL ou defina manualmente.
# NEXT_PUBLIC_SITE_URL=https://sistema-bibi.netlify.app

# --- Seed e modo demo ---
# DUAL_DATA_STORE=true   # seletor demo/operação (padrão: true em dev e Netlify)
# DATA_STORE_MODE=demo   # modo inicial: demo | operation
# APP_MODE=demo          # legado — mapeia para modo inicial
# RUN_SEED_ON_BUILD=true # false = build sem seed (obrigatório em operação)
# Volume da massa: small | medium (padrão) | large
# SEED_SCALE=medium

# Botão "Restaurar demo" em /interno/seguranca (desligado em APP_MODE=operation)
ALLOW_DEMO_RESET=true

# --- Assistente IA (chat operacional) ---
# Padrão em dev: ligado, provider mock (sem chaves OpenAI).
# ASSISTANT_ENABLED=false        # desliga UI + API do assistente
# ASSISTANT_PROVIDER=mock        # mock (dev) | netlify-gateway (produção com AI Gateway)
# ASSISTANT_MODEL=gpt-4o-mini
# Netlify AI Gateway (auto-injetado após deploy + AI habilitado no painel):
# OPENAI_BASE_URL=
# OPENAI_API_KEY=

# --- Plataforma (geralmente automático — não editar localmente) ---
# NETLIFY=true          # injetado no deploy Netlify (netlify.toml)
# NODE_ENV=development  # definido pelo Next.js
# URL=                  # injetado pela Netlify com a URL do site
