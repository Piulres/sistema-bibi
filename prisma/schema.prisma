// Sistema Bibi - HealthTech SaaS (POC)
// Modelo inspirado na ERPMed/Centtralmed: multi-tenancy, Pay Per Use,
// gestao de beneficiarios e faturamento de procedimentos.
//
// Nota: SQLite nao suporta enums no Prisma; usamos String com valores
// documentados nos comentarios de cada campo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Cliente do SaaS (clinica ou hospital). Base da segregacao multi-tenant.
model Tenant {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  createdAt DateTime @default(now())

  users        User[]
  companies    Company[]
  patients     Patient[]
  procedures   Procedure[]
  appointments Appointment[]
  invoices     Invoice[]
  subscriptions Subscription[]
  timelineEvents TimelineEvent[]
  messages       Message[]
  branding       TenantBranding?
}

/// Identidade visual white-label por tenant (logo, cores, nome de exibicao).
model TenantBranding {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Nome comercial exibido na UI (pode diferir de Tenant.name).
  displayName  String
  tagline      String?
  logoUrl      String?
  /// Cores em hex (#RRGGBB). Injetadas como CSS variables em runtime.
  primaryColor   String @default("#0d9488")
  accentColor    String @default("#14b8a6")
  heroFrom       String @default("#0f172a")
  heroTo         String @default("#134e4a")
  /// Nome da plataforma quando exibido como produto white-label (ex. "Powered by Bibi").
  platformLabel  String @default("Sistema Bibi")
  /// colorScheme: light | dark | system
  colorScheme    String @default("light")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Usuario do sistema. role define o portal de acesso.
/// role: PRESTADOR | INTERNO | PJ | BENEFICIARIO
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  // POC: senha em texto puro apenas para demonstracao. Em producao usar hash (ex. bcrypt/argon2).
  password  String
  name      String
  role      String
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Vinculo opcional com empresa (para usuarios do Portal PJ).
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Vinculo opcional com beneficiario (Portal Beneficiario).
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  appointments   Appointment[]   @relation("ProviderAppointments")
  medicalRecords MedicalRecord[] @relation("ProviderRecords")
}

/// Empresa contratante (Pessoa Juridica) - Portal PJ.
/// status: LEAD | PROPOSTA | NEGOCIACAO | ATIVO | INADIMPLENTE | CANCELADO
model Company {
  id             String   @id @default(cuid())
  name           String
  cnpj           String   @unique
  status         String   @default("ATIVO")
  contractActive Boolean  @default(true)
  createdAt      DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  users        User[]
  patients     Patient[]
  pricingRules PricingRule[]
  invoices     Invoice[]
  subscriptions Subscription[]
}

/// Beneficiario / paciente. Pode ser individual ou vinculado a uma empresa (PJ).
model Patient {
  id        String   @id @default(cuid())
  name      String
  cpf       String   @unique
  birthDate DateTime
  phone     String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  users          User[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  invoices       Invoice[]
  subscriptions  Subscription[]
  messages       Message[]
}

/// Catalogo de procedimentos (consultas e exames) com preco base.
/// category: CONSULTA | EXAME
model Procedure {
  id        String   @id @default(cuid())
  code      String
  name      String
  category  String
  basePrice Float
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  pricingRules PricingRule[]
  usages       ProcedureUsage[]

  @@unique([tenantId, code])
}

/// Precificacao dinamica: ajusta o preco base por empresa (ex.: desconto corporativo).
model PricingRule {
  id          String  @id @default(cuid())
  description String
  // Multiplicador aplicado ao preco base (ex.: 0.8 = 20% de desconto).
  multiplier  Float   @default(1.0)

  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
}

/// Agendamento (Agenda Inteligente).
/// status: AGENDADO | CONFIRMADO | REALIZADO | FALTOU | CANCELADO
model Appointment {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  status      String   @default("AGENDADO")
  reason      String?
  createdAt   DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  providerId String
  provider   User   @relation("ProviderAppointments", fields: [providerId], references: [id])

  usages         ProcedureUsage[]
  medicalRecords MedicalRecord[]
}

/// Uso efetivo de procedimento (nucleo do Pay Per Use).
/// Registra o preco cobrado no momento do uso (snapshot), garantindo
/// transparencia previa e previsibilidade financeira.
model ProcedureUsage {
  id          String   @id @default(cuid())
  priceCharged Float
  performedAt DateTime @default(now())
  billed      Boolean  @default(false)

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  invoiceItem InvoiceItem?
}

/// Prontuario Eletronico do Paciente (PEP).
model MedicalRecord {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  providerId String
  provider   User   @relation("ProviderRecords", fields: [providerId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

/// Fatura Pay Per Use - agrega os procedimentos efetivamente utilizados.
/// status: ABERTA | FECHADA | PAGA
model Invoice {
  id        String   @id @default(cuid())
  total     Float    @default(0)
  status    String   @default("FECHADA")
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  items InvoiceItem[]
  subscriptionCharges SubscriptionCharge[]
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  amount      Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  usageId String         @unique
  usage   ProcedureUsage @relation(fields: [usageId], references: [id])
}

/// Auditoria universal de eventos do sistema (Timeline).
/// entityType: User | Patient | Appointment | ProcedureUsage | MedicalRecord | Invoice | Company
/// action: LOGIN | CREATED | UPDATED | APPOINTMENT_COMPLETED | PROCEDURE_REGISTERED |
///         MEDICAL_RECORD_CREATED | INVOICE_ISSUED | CHARGE_SENT | CONTRACT_CHANGED
model TimelineEvent {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String
  entityId    String
  action      String
  description String
  createdAt   DateTime @default(now())
  createdBy   String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

/// Assinatura recorrente vinculada a beneficiario e/ou empresa.
/// status: ATIVA | SUSPENSA | CANCELADA
/// billingCycle: MENSAL | TRIMESTRAL | SEMESTRAL | ANUAL
model Subscription {
  id           String    @id @default(cuid())
  status       String    @default("ATIVA")
  billingCycle String
  startDate    DateTime
  endDate      DateTime?
  /// Valor cobrado a cada ciclo (recorrencia).
  amount       Float     @default(0)
  description  String?
  createdAt    DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  charges SubscriptionCharge[]
}

/// Cobranca futura gerada a partir de uma assinatura.
/// status: PENDENTE | FATURADA | CANCELADA
model SubscriptionCharge {
  id        String   @id @default(cuid())
  dueDate   DateTime
  amount    Float
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

/// Comunicacao outbound (email, SMS, WhatsApp) enfileirada ou enviada.
/// channel: EMAIL | SMS | WHATSAPP
/// template: APPOINTMENT_REMINDER | INVOICE_DUE | SUBSCRIPTION_DUE | GENERIC
/// status: PENDENTE | ENVIADA | FALHA | CANCELADA
model Message {
  id         String    @id @default(cuid())
  channel    String
  template   String    @default("GENERIC")
  subject    String?
  body       String
  status     String    @default("PENDENTE")
  externalId String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  createdBy String?
}
