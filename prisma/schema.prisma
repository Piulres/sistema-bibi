// Sistema Bibi v2.0 — ServiceOS Multi-Nicho (POC)
// Infraestrutura horizontal Pay Per Use: Saúde, Veterinária, Odontologia,
// Jurídico, Bem-estar e Educação via parametrização por tenant (niche + labels).
//
// Nota: SQLite nao suporta enums no Prisma; usamos String com valores
// documentados nos comentarios de cada campo.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Cliente do SaaS (clínica, escritório, pet shop, etc.). Base da segregação multi-tenant.
model Tenant {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  /// Slug único para roteamento (?tenant=petcare) e identificação do segmento
  slug      String   @unique
  /// Nicho operacional: MEDICAL | VET | DENTAL | LEGAL | SPA | EDUCATION
  niche     String   @default("MEDICAL")
  /// JSON — dicionário de termos da UI (ex.: patient → "Pet" no nicho VET)
  labels    String?
  createdAt DateTime @default(now())

  users        User[]
  companies    Company[]
  patients     Patient[]
  procedures   Procedure[]
  appointments Appointment[]
  invoices     Invoice[]
  subscriptions Subscription[]
  timelineEvents TimelineEvent[]
  messages       Message[]
  branding       TenantBranding?
  webhooks       WebhookEndpoint[]
  careProtocolTemplates CareProtocolTemplate[]
  medicalProducts       MedicalProduct[]
  stockLots             StockLot[]
  stockMovements        StockMovement[]
  procedureMaterialKits ProcedureMaterialKit[]
}

/// Identidade visual white-label por tenant (logo, cores, nome de exibicao).
model TenantBranding {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Nome comercial exibido na UI (pode diferir de Tenant.name).
  displayName  String
  tagline      String?
  logoUrl      String?
  /// Cores em hex (#RRGGBB). Injetadas como CSS variables em runtime.
  primaryColor   String @default("#0d9488")
  accentColor    String @default("#14b8a6")
  heroFrom       String @default("#0f172a")
  heroTo         String @default("#134e4a")
  /// Nome da plataforma quando exibido como produto white-label (ex. "Powered by Bibi").
  platformLabel  String @default("Sistema Bibi")
  /// colorScheme: light | dark | system
  colorScheme    String @default("light")
  /// Dominio customizado white-label (ex.: saude.cliente.com.br) — DNS manual na POC
  customDomain   String? @unique
  customDomainVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Usuario do sistema. role define o portal de acesso.
/// role: PRESTADOR | INTERNO | PJ | BENEFICIARIO
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  // Senha com hash scrypt (ver src/lib/password.ts). Seed usa hashPassword().
  password  String
  name      String
  role      String
  /// Perfil granular do portal interno: ADMIN | FATURAMENTO | RECEPCAO | READONLY (null = ADMIN)
  internoProfile String?
  /// MFA TOTP (Tier 4) — secret base32; habilitado quando mfaEnabled=true
  mfaEnabled Boolean @default(false)
  mfaSecret  String?
  /// Telefone de contato (prestador / interno)
  phone          String?
  /// Conselho profissional (prestador): CRM | CRO | CRP | COREN | OUTRO
  councilType    String?
  councilNumber  String?
  councilUf      String?
  specialty      String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Vinculo opcional com empresa (para usuarios do Portal PJ).
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Vinculo opcional com beneficiario (Portal Beneficiario).
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id])

  appointments   Appointment[]   @relation("ProviderAppointments")
  medicalRecords MedicalRecord[] @relation("ProviderRecords")
  medicationPrescriptions MedicationPrescription[] @relation("ProviderPrescriptions")
  examOrders     ExamOrder[]     @relation("ProviderExamOrders")
  protocolEnrollments PatientProtocolEnrollment[] @relation("ProviderProtocolEnrollments")
}

/// Empresa contratante (Pessoa Juridica) - Portal PJ.
/// name = razão social · status: LEAD | PROPOSTA | NEGOCIACAO | ATIVO | INADIMPLENTE | CANCELADO
model Company {
  id             String   @id @default(cuid())
  name           String
  cnpj           String   @unique
  tradeName      String?
  email          String?
  phone          String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  addressStreet  String?
  addressCity    String?
  addressState   String?
  addressZip     String?
  status         String   @default("ATIVO")
  contractActive Boolean  @default(true)
  createdAt      DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  users        User[]
  patients     Patient[]
  pricingRules PricingRule[]
  invoices     Invoice[]
  subscriptions Subscription[]
}

/// Beneficiario / paciente. Pode ser individual ou vinculado a uma empresa (PJ).
model Patient {
  id        String   @id @default(cuid())
  name      String
  cpf       String   @unique
  birthDate DateTime
  phone     String?
  email     String?
  /// M | F | O | NI
  gender    String?
  motherName String?
  /// Matrícula / código na empresa
  employeeId String?
  /// TITULAR | DEPENDENTE | SOCIO
  bondType  String?
  /// LGPD — consentimento para tratamento de dados
  consentAt      DateTime?
  consentVersion String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  users          User[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  clinicalProfile PatientClinicalProfile?
  medicationPrescriptions MedicationPrescription[]
  examOrders     ExamOrder[]
  protocolEnrollments PatientProtocolEnrollment[]
  invoices       Invoice[]
  subscriptions  Subscription[]
  messages       Message[]
}

/// Catálogo de serviços agnóstico — consulta médica, hora técnica jurídica, banho e tosa, etc.
/// category: CONSULTA | EXAME | SERVICO | SESSAO | OCUPACIONAL
/// serviceType: classificação livre por nicho (ex.: CLINICA, JURIDICO, ESTETICA)
model Procedure {
  id          String   @id @default(cuid())
  code        String
  name        String
  category    String
  serviceType String?
  basePrice   Float
  /// Código regulatório opcional (TUSS/ANS, OAB, etc.)
  tissCode    String?
  createdAt   DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  pricingRules PricingRule[]
  usages       ProcedureUsage[]
  examOrders   ExamOrder[]
  materialKits ProcedureMaterialKit[]

  @@unique([tenantId, code])
}

/// Catálogo de produtos médicos (medicamentos, materiais, OPME, insumos).
/// category: MEDICAMENTO | MATERIAL | OPME | INSUMO
/// unit: UN | ML | CX | PC | FR
model MedicalProduct {
  id          String   @id @default(cuid())
  sku         String
  name        String
  category    String
  unit        String   @default("UN")
  minStock    Float    @default(0)
  /// Registro ANVISA / código de barras (opcional)
  anvisaCode  String?
  requiresLot Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  lots      StockLot[]
  movements StockMovement[]
  kitItems  ProcedureMaterialKit[]

  @@unique([tenantId, sku])
  @@index([tenantId, category, active])
}

/// Lote em estoque — rastreabilidade (RDC 304/2019).
/// status: DISPONIVEL | BLOQUEADO | VENCIDO | QUARENTENA
model StockLot {
  id         String   @id @default(cuid())
  lotNumber  String
  expiryDate DateTime
  quantity   Float
  unitCost   Float    @default(0)
  status     String   @default("DISPONIVEL")
  supplierRef String?
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  productId String
  product   MedicalProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  movements StockMovement[]

  @@unique([productId, lotNumber])
  @@index([tenantId, expiryDate])
  @@index([productId, status])
}

/// Movimentação de estoque.
/// type: ENTRADA | SAIDA | AJUSTE | DISPENSACAO | TRANSFERENCIA | PERDA | DEVOLUCAO
model StockMovement {
  id               String   @id @default(cuid())
  type             String
  quantity         Float
  unitCost         Float?
  reason           String?
  appointmentId    String?
  patientId        String?
  procedureUsageId String?
  createdAt        DateTime @default(now())
  createdBy        String?

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  productId String
  product   MedicalProduct @relation(fields: [productId], references: [id])
  lotId     String?
  lot       StockLot? @relation(fields: [lotId], references: [id])

  @@index([tenantId, createdAt])
  @@index([productId])
  @@index([patientId])
}

/// Kit de materiais vinculado a procedimento (baixa automática no Pay Per Use).
model ProcedureMaterialKit {
  id       String @id @default(cuid())
  quantity Float  @default(1)

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  productId   String
  product     MedicalProduct @relation(fields: [productId], references: [id])

  @@unique([procedureId, productId])
}

/// Precificacao dinamica: ajusta o preco base por empresa (ex.: desconto corporativo).
model PricingRule {
  id          String  @id @default(cuid())
  description String
  // Multiplicador aplicado ao preco base (ex.: 0.8 = 20% de desconto).
  multiplier  Float   @default(1.0)

  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
}

/// Agendamento (Agenda Inteligente).
/// status: AGENDADO | CONFIRMADO | REALIZADO | FALTOU | CANCELADO
/// modality: PRESENCIAL | TELE
model Appointment {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  status      String   @default("AGENDADO")
  modality    String   @default("PRESENCIAL")
  /// Link da sala de telemedicina (gerado automaticamente quando modality=TELE)
  telemedicineUrl String?
  reason      String?
  createdAt   DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  providerId String
  provider   User   @relation("ProviderAppointments", fields: [providerId], references: [id])

  usages         ProcedureUsage[]
  medicalRecords MedicalRecord[]
  medicationPrescriptions MedicationPrescription[]
  examOrders     ExamOrder[]
  protocolEnrollments PatientProtocolEnrollment[]
}

/// Uso efetivo de procedimento (nucleo do Pay Per Use).
/// Registra o preco cobrado no momento do uso (snapshot), garantindo
/// transparencia previa e previsibilidade financeira.
model ProcedureUsage {
  id          String   @id @default(cuid())
  priceCharged Float
  performedAt DateTime @default(now())
  billed      Boolean  @default(false)

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  procedureId String
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  invoiceItem InvoiceItem?
}

/// Prontuario Eletronico do Paciente (PEP).
/// recordType: EVOLUCAO | ANAMNESE | RECEITA | ATESTADO
model MedicalRecord {
  id         String   @id @default(cuid())
  recordType String   @default("EVOLUCAO")
  title      String?
  content    String
  createdAt  DateTime @default(now())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  providerId String
  provider   User   @relation("ProviderRecords", fields: [providerId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

/// Perfil clínico persistente do paciente (alergias, condições crônicas).
model PatientClinicalProfile {
  id                String   @id @default(cuid())
  patientId         String   @unique
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// JSON: [{ substance, severity, notes }]
  allergies         String?
  /// JSON: [{ condition, since, notes }]
  chronicConditions String?
  bloodType         String?
  updatedAt         DateTime @updatedAt
}

/// Prescrição estruturada de medicação.
/// status: ATIVA | SUSPENSA | ENCERRADA
model MedicationPrescription {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId    String
  provider      User     @relation("ProviderPrescriptions", fields: [providerId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  status        String   @default("ATIVA")
  medication    String
  dosage        String
  frequency     String
  route         String?
  durationDays  Int?
  notes         String?
  startDate     DateTime @default(now())
  endDate       DateTime?
  createdAt     DateTime @default(now())

  @@index([patientId, status])
}

/// Pedido de exame (workflow clínico).
/// status: SOLICITADO | AGENDADO | REALIZADO | LAUDADO | CANCELADO
model ExamOrder {
  id                  String   @id @default(cuid())
  patientId           String
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId          String
  provider            User     @relation("ProviderExamOrders", fields: [providerId], references: [id])
  appointmentId       String?
  appointment         Appointment? @relation(fields: [appointmentId], references: [id])
  procedureId         String?
  procedure           Procedure? @relation(fields: [procedureId], references: [id])
  examName            String
  status              String   @default("SOLICITADO")
  clinicalIndication  String?
  scheduledAt         DateTime?
  resultSummary       String?
  resultAttachmentKey String?
  reviewedAt          DateTime?
  createdAt           DateTime @default(now())

  @@index([patientId, status])
}

/// Template de protocolo de cuidado por tenant.
model CareProtocolTemplate {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  specialty           String?
  /// JSON: [{ id, label, required }]
  checklist           String
  suggestedReturnDays Int?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  enrollments PatientProtocolEnrollment[]

  @@index([tenantId, active])
}

/// Matrícula do paciente em um protocolo de cuidado.
/// status: ATIVO | CONCLUIDO | SUSPENSO
model PatientProtocolEnrollment {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  templateId     String
  template       CareProtocolTemplate @relation(fields: [templateId], references: [id])
  providerId     String
  provider       User     @relation("ProviderProtocolEnrollments", fields: [providerId], references: [id])
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  status         String   @default("ATIVO")
  /// JSON: { [checklistItemId]: boolean }
  checklistState String   @default("{}")
  startedAt      DateTime @default(now())
  nextReviewAt   DateTime?

  @@index([patientId, status])
}

/// Fatura Pay Per Use - agrega os procedimentos efetivamente utilizados.
/// status: ABERTA | FECHADA | PAGA
model Invoice {
  id        String   @id @default(cuid())
  total     Float    @default(0)
  status    String   @default("FECHADA")
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  items InvoiceItem[]
  subscriptionCharges SubscriptionCharge[]
  payments Payment[]
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  amount      Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  usageId String?         @unique
  usage   ProcedureUsage? @relation(fields: [usageId], references: [id])

  subscriptionChargeId String?             @unique
  subscriptionCharge   SubscriptionCharge? @relation(fields: [subscriptionChargeId], references: [id])
}

/// Registro de pagamento vinculado a uma fatura (PIX, manual, etc.).
/// status: PENDING | CONFIRMED | FAILED | CANCELLED
model Payment {
  id            String    @id @default(cuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  method        String
  amount        Float
  status        String    @default("PENDING")
  gatewayId     String?
  externalId    String?
  pixCopyPaste  String?
  qrCodePayload String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  createdBy     String?
  metadata      String?

  @@index([invoiceId])
  @@index([externalId])
}

/// Auditoria universal de eventos do sistema (Timeline).
/// entityType: User | Patient | Appointment | ProcedureUsage | MedicalRecord | Invoice | Company
/// action: LOGIN | CREATED | UPDATED | APPOINTMENT_COMPLETED | PROCEDURE_REGISTERED |
///         MEDICAL_RECORD_CREATED | INVOICE_ISSUED | CHARGE_SENT | CONTRACT_CHANGED
model TimelineEvent {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String
  entityId    String
  action      String
  description String
  createdAt   DateTime @default(now())
  createdBy   String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

/// Assinatura recorrente vinculada a beneficiario e/ou empresa.
/// status: ATIVA | SUSPENSA | CANCELADA
/// billingCycle: MENSAL | TRIMESTRAL | SEMESTRAL | ANUAL
model Subscription {
  id           String    @id @default(cuid())
  status       String    @default("ATIVA")
  billingCycle String
  startDate    DateTime
  endDate      DateTime?
  /// Valor cobrado a cada ciclo (recorrencia).
  amount       Float     @default(0)
  description  String?
  createdAt    DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  charges SubscriptionCharge[]
}

/// Cobranca futura gerada a partir de uma assinatura.
/// status: PENDENTE | FATURADA | CANCELADA
model SubscriptionCharge {
  id        String   @id @default(cuid())
  dueDate   DateTime
  amount    Float
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  invoiceItem InvoiceItem?
}

/// Comunicacao outbound (email, SMS, WhatsApp) enfileirada ou enviada.
/// channel: EMAIL | SMS | WHATSAPP
/// template: APPOINTMENT_REMINDER | INVOICE_DUE | SUBSCRIPTION_DUE | GENERIC
/// status: PENDENTE | ENVIADA | FALHA | CANCELADA
model Message {
  id         String    @id @default(cuid())
  channel    String
  template   String    @default("GENERIC")
  subject    String?
  body       String
  status     String    @default("PENDENTE")
  externalId String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  createdBy String?
}

/// Webhook outbound para integrações B2B do tenant.
/// events: JSON array — INVOICE_ISSUED | APPOINTMENT_CREATED | COMPANY_STATUS_CHANGED | PATIENT_CREATED
model WebhookEndpoint {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String
  url       String
  secret    String?
  events    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

/// Log de entrega de webhook com suporte a retry (Tier 4).
/// status: SUCCESS | FAILED | PENDING
model WebhookDelivery {
  id           String   @id @default(cuid())
  tenantId     String
  webhookId    String
  webhook      WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  payload      String
  status       String   @default("PENDING")
  httpStatus   Int?
  errorMessage String?
  attempt      Int      @default(1)
  maxAttempts  Int      @default(5)
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())
  deliveredAt  DateTime?

  @@index([tenantId, status, nextRetryAt])
  @@index([webhookId, createdAt])
}
